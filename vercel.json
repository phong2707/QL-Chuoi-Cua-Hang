{
  "version": 2,
  "builds": [
    {
      "src": "server/src/configs/application.ts",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/src/configs/application.ts"
    },
    {
      "source": "/(.*)",
      "destination": "client/dist/index.html"
    }
  ]
}